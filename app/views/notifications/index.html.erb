<%# User inbox - lists all notifications. Admin button to compose a new one. MJR %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Notifications</h1>
    <%# Only visible to admin users. MJR %>
    <% if current_user.admin? %>
      <%= link_to new_notification_path, class: "btn btn-primary" do %>
        <i class="fa fa-plus me-2"></i> New Notification
      <% end %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <div class="list-group">
      <%# Bold unread notifications and show a New badge. MJR %>
      <% @notifications.each do |notification| %>
        <%= link_to notification_path(notification), class: "list-group-item list-group-item-action #{"fw-bold" unless notification.read?}" do %>
          <div class="d-flex justify-content-between align-items-center">
            <span><%= notification.params[:title] %></span>
            <small class="text-muted"><%= notification.created_at.strftime("%b %d, %Y") %></small>
          </div>
          <% unless notification.read? %>
            <span class="badge bg-primary">New</span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p>No notifications yet.</p>
  <% end %>
</div>
