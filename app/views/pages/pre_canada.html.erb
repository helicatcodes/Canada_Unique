<div class="pre-canada">

  <%= button_to "↻ Sync Tasks", sync_tasks_path, method: :post,
      style: "background: none; border: 1px solid #ccc; border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: #555; cursor: pointer; float: right;" %>

  <%# ── Card 1: Countdown ── %>
  <div class="pre-canada__card pre-canada__countdown">
    <h2 class="pre-canada__card-title">Your countdown</h2>
    <span class="pre-canada__countdown-number"><%= @countdown %></span>
    <span class="pre-canada__countdown-label">days until departure</span>
  </div>

  <%# ── Card 2: Obligatory tasks ── %>
  <div class="pre-canada__card">
    <h2 class="pre-canada__card-title">Obligatory tasks</h2>
    <%= render 'tasks/task_list', tasks: effective_user.tasks.where(obligatory: true) %>
  </div>

  <%# ── Card 3: Next steps ── %>
  <div class="pre-canada__card">
    <h2 class="pre-canada__card-title">Next steps</h2>
    <p class="pre-canada__tasks-intro">Find more information about your new home for the next year to be perfectly prepared for your adventure to come!</p>
    <%= render 'tasks/task_list', tasks: effective_user.tasks.where(obligatory: false) %>
  </div>

</div>
