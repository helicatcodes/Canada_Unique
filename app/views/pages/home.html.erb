<h1>Pages#home - CA Logo goes here</h1>

<% if user_signed_in? %>
  <p class="text-center mb-3">Welcome back, <%= current_user.display_name %>!</p>
<% end %>

<div class="flex-container">
  <%= link_to pre_canada_path do %>
  <div class="card flex-item rounded" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(<%= asset_path 'pre_canada_image.jpg' %>);">
    <div class="font-homepage">
      <h1>Let's get ready for Canada</h1>
    </div>
  </div>
  <% end %>
  <br>
  <%= link_to in_canada_path do %>
  <div class="card flex-item" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(<%= asset_path 'pre_canada_image.jpg' %>);">
    <div class="font-homepage">
      <h1>Canada Moments</h1>
    </div>
  </div>
  <% end  %>
  <br>
  <%= link_to post_canada_path do %>
  <div class="card flex-item" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(<%= asset_path 'pre_canada_image.jpg' %>);">
    <div class="font-homepage">
      <h1>Welcome back</h1>
    </div>
  </div>
  <% end  %>
</div>
