<div class="container mt-4">
  <h1 class="mb-4">Canada Community</h1>

  <%# Upload section %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">Upload a Photo</h2>
    <%= simple_form_for @photo, url: photos_path do |f| %>
      <%= f.input :image, as: :file, label: "Choose a photo" %>
      <%= f.input :description, placeholder: "Add a caption..." %>
      <%= f.submit "Upload", class: "btn btn-primary" %>
    <% end %>
  </div>

  <%# My Photos section — only the current user's photos, with icon action buttons %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">My Photos</h2>
    <% if @my_photos.none? %>
      <p class="text-muted">You haven't uploaded any photos yet.</p>
    <% else %>
      <div class="photo-grid">
        <% @my_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div class="photo-card">
              <%= image_tag photo.image, class: "photo-card__img" %>
              <div class="photo-card__body">
                <p class="photo-card__desc"><%= photo.description %></p>
                <%# [HW] Icon buttons in one row: edit (pen), delete (trash), share/unshare (share-nodes) %>
                <%# [HW] button_to generates a <form> — .photo-actions sets those forms to inline-flex %>
                <div class="photo-actions">
                  <%= link_to edit_photo_path(photo), class: "photo-action-btn", title: "Edit caption" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%= button_to photo_path(photo), method: :delete,
                      class: "photo-action-btn photo-action-btn--danger",
                      title: "Delete photo",
                      data: { turbo_confirm: "Are you sure?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                  <%# [HW] link_to with data-turbo-method: :patch is the Turbo-native way to make %>
                  <%# a PATCH request from a link/icon without needing a form wrapper %>
                  <%# shared? → navy filled icon. Not shared? → grey outline icon %>
                  <%= link_to toggle_share_photo_path(photo),
                      data: { turbo_method: :patch },
                      class: "photo-action-btn #{ photo.shared ? 'photo-action-btn--active' : '' }",
                      title: photo.shared ? "Unshare from feed" : "Share to community feed" do %>
                    <i class="fa-solid fa-share-nodes"></i>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Community Feed — all photos explicitly shared by any user %>
  <div class="cu-panel">
    <h2 class="cu-panel__title">Community Feed</h2>
    <% if @feed_photos.none? %>
      <p class="text-muted">No photos shared yet — be the first!</p>
    <% else %>
      <div class="photo-grid">
        <% @feed_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div class="photo-card">
              <%= image_tag photo.image, class: "photo-card__img" %>
              <div class="photo-card__body">
                <p class="photo-card__desc"><%= photo.description %></p>
                <small class="text-muted">By <%= photo.user.name %></small>

                <%# [HW] Like button — checks in-memory loaded likes (no extra DB query) %>
                <%# [HW] already_liked uses .any? on the already-loaded likes array %>
                <% already_liked = photo.likes.any? { |l| l.user_id == current_user.id } %>
                <div class="photo-actions mt-2">
                  <%= button_to photo_likes_path(photo), method: :post,
                      class: "photo-action-btn #{ already_liked ? 'photo-action-btn--liked' : '' }",
                      title: already_liked ? "Unlike" : "Like" do %>
                    <i class="fa-#{ already_liked ? 'solid' : 'regular' } fa-heart"></i>
                    <span class="ms-1"><%= photo.likes.size %></span>
                  <% end %>
                </div>

                <%# [HW] Comments list — loops over already-loaded comments (no extra DB query) %>
                <div class="feed-comments mt-2">
                  <% photo.comments.each do |comment| %>
                    <div class="feed-comment">
                      <strong><%= comment.user.name %></strong> <%= comment.text %>
                      <%# [HW] Delete button only visible to the comment's author %>
                      <% if comment.user == current_user %>
                        <%= button_to photo_comment_path(photo, comment), method: :delete,
                            class: "feed-comment__delete", title: "Delete comment" do %>
                          <i class="fa-solid fa-xmark"></i>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>

                <%# [HW] Comment form — posts to CommentsController#create via nested route %>
                <%= simple_form_for [photo, Comment.new], url: photo_comments_path(photo) do |f| %>
                  <div class="d-flex gap-1 mt-2">
                    <%= f.input :text, label: false, placeholder: "Add a comment...",
                        wrapper: false, input_html: { class: "form-control form-control-sm" } %>
                    <%= f.submit "Post", class: "btn btn-sm btn-primary" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
