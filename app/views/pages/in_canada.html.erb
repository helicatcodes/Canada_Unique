<div class="container mt-4">
  <h1 class="mb-3">Canada Moments</h1>

  <%# [HW] Bootstrap tab bar — data-bs-toggle="tab" and data-bs-target are all Bootstrap needs %>
  <%# [HW] No custom JavaScript required — Bootstrap's bundled JS handles show/hide %>
  <ul class="nav nav-tabs cu-tabs" id="canadaTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' unless params[:active_tab] == 'gallery' %>" id="feed-tab"
              data-bs-toggle="tab" data-bs-target="#tab-feed"
              type="button" role="tab">
        Community
      </button>
    </li>
    <li class="nav-item nav-item--with-action" role="presentation">
      <button class="nav-link <%= 'active' if params[:active_tab] == 'gallery' %>" id="my-photos-tab"
              data-bs-toggle="tab" data-bs-target="#tab-my-photos"
              type="button" role="tab">
        Gallery
      </button>
      <%# [HW] "+" opens the upload modal — not a tab, so no data-bs-toggle="tab" %>
      <button class="add-photo-btn" type="button"
              data-bs-toggle="modal" data-bs-target="#add-photo-modal"
              title="Add photo">
        <i class="fa-solid fa-plus"></i>
      </button>
    </li>
  </ul>

  <div class="tab-content cu-tab-content">

    <%# ============================================================ %>
    <%# TAB 1 — Community Feed %>
    <%# show + active makes this the default visible tab on page load %>
    <%# ============================================================ %>
    <div class="tab-pane fade <%= 'show active' unless params[:active_tab] == 'gallery' %>" id="tab-feed" role="tabpanel">
      <% if @feed_photos.none? %>
        <p class="text-muted mt-3">No photos shared yet — be the first!</p>
      <% else %>
        <%# [HW] Tight square grid — 2 cols mobile, 3 cols from sm breakpoint up %>
        <div class="feed-grid">
          <% @feed_photos.each do |photo| %>
            <% if photo.image.attached? %>

              <%# [HW] Thumbnail card — white frame around the photo, author above, caption below %>
              <%# [HW] The whole card is the click target for the modal %>
              <div class="feed-grid__item"
                   data-bs-toggle="modal"
                   data-bs-target="#photo-modal-<%= photo.id %>">

                <%# [HW] Author row: avatar circle immediately left of the name, both in one flex row %>
                <div class="feed-grid__author">
                  <%# [HW] stopPropagation stops the click bubbling up to the card's photo modal %>
                  <%# [HW] so only the avatar modal fires when the circle is clicked %>
                  <span onclick="event.stopPropagation()"
                        data-bs-toggle="modal"
                        data-bs-target="#avatar-modal-<%= photo.user.id %>"
                        class="feed-grid__avatar-trigger"
                        title="View <%= photo.user.name %>'s profile">
                    <% if photo.user.avatar.attached? %>
                      <%= image_tag photo.user.avatar, class: "feed-grid__avatar" %>
                    <% else %>
                      <span class="feed-grid__avatar feed-grid__avatar--placeholder">
                        <i class="fa fa-user"></i>
                      </span>
                    <% end %>
                  </span>
                  <span class="feed-grid__author-name"><%= photo.user.name %></span>
                </div>

                <%# [HW] Location row — shown only when the photo has a location tag %>
                <%# [HW] Sits on the white frame between the author row and the photo %>
                <% if photo.location.present? %>
                  <div class="feed-grid__location">
                    <i class="fa-solid fa-location-dot"></i>
                    <span><%= photo.location %></span>
                  </div>
                <% end %>

                <%# [HW] Photo wrapper — position:relative here so the overlay is scoped to the photo %>
                <%# [HW] only, not bleeding into the author/caption rows %>
                <div class="feed-grid__photo-wrap">
                  <%= image_tag photo.image, class: "feed-grid__img", alt: photo.description %>
                  <div class="feed-grid__overlay">
                    <span id="feed-overlay-likes-<%= photo.id %>"><i class="fa-solid fa-heart"></i> <%= photo.likes.size %></span>
                    <span id="feed-overlay-comments-<%= photo.id %>"><i class="fa-solid fa-comment"></i> <%= photo.comments.size %></span>
                  </div>
                </div>

                <%# [HW] Caption row — centered below the photo in the bottom white area %>
                <div class="feed-grid__caption"><%= photo.description %></div>

              </div>

              <%# [HW] Bootstrap modal for this photo — hidden until the thumbnail above is clicked %>
              <%# [HW] Each modal needs a unique id — photo.id makes it unique per photo %>
              <%# [HW] Modal — narrower (modal-md) and stacked like a polaroid: photo on top, content below %>
              <%# [HW] Modal — modal-lg gives ~800px width, styled as a zoomed polaroid card %>
              <div class="modal fade feed-modal" id="photo-modal-<%= photo.id %>"
                   tabindex="-1" aria-label="<%= photo.user.display_name %>'s photo">
                <div class="modal-dialog modal-dialog-centered">
                  <div class="modal-content">

                    <%# [HW] Close button floats over the top-right corner of the photo %>
                    <button class="feed-modal__close" data-bs-dismiss="modal" aria-label="Close">
                      <i class="fa-solid fa-xmark"></i>
                    </button>

                    <%# [HW] Location in the white frame above the image — right-aligned, top-right corner %>
                    <% if photo.location.present? %>
                      <div class="feed-modal__above-img">
                        <i class="fa-solid fa-location-dot"></i>
                        <span><%= photo.location %></span>
                      </div>
                    <% end %>

                    <%# [HW] Photo fills the white frame, square crop matching the grid thumbnail %>
                    <%= image_tag photo.image, class: "feed-modal__img", alt: photo.description %>

                    <%# [HW] Content below photo — order mirrors how a physical polaroid reads: %>
                    <%# [HW] counts → who took it → what it says → what others said %>
                    <div class="feed-modal__content">

                      <%# [HW] Reactions right below the photo — like count and comment count %>
                      <%= render "likes/reactions", photo: photo %>

                      <%# [HW] Author name + caption — bold name inline before the description %>
                      <p class="photo-card__desc">
                        <strong class="photo-card__author"><%= photo.user.display_name %></strong>
                        <%= photo.description %>
                      </p>

                      <%# [HW] Additional comments below — id is the Turbo Stream append target %>
                      <div id="feed-comments-<%= photo.id %>" class="feed-comments">
                        <% photo.comments.each do |comment| %>
                          <%= render "comments/comment", comment: comment, photo: photo %>
                        <% end %>
                      </div>

                      <%# [HW] Comment form at the bottom %>
                      <%= render "comments/form", photo: photo %>

                    </div>

                  </div>
                </div>
              </div>

            <% end %>
          <% end %>
        </div>
      <%# [HW] Avatar modals — rendered once per unique author outside the photo loop %>
      <%# [HW] Putting them inside the loop would produce duplicate ids when one user %>
      <%# [HW] has multiple photos — duplicate ids are invalid HTML and confuse Bootstrap %>
      <% @feed_photos.map(&:user).uniq.each do |feed_user| %>
        <div class="modal fade feed-modal" id="avatar-modal-<%= feed_user.id %>"
             tabindex="-1" aria-label="<%= feed_user.name %>'s profile">
          <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">

              <button class="feed-modal__close" data-bs-dismiss="modal" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
              </button>

              <%# [HW] Avatar centred inside the polaroid white frame %>
              <div class="feed-avatar-modal__img-wrap">
                <% if feed_user.avatar.attached? %>
                  <%= image_tag feed_user.avatar, class: "feed-avatar-modal__img" %>
                <% else %>
                  <div class="feed-avatar-modal__img feed-avatar-modal__img--placeholder">
                    <i class="fa fa-user"></i>
                  </div>
                <% end %>
              </div>

              <%# [HW] Name and status in the bottom white area %>
              <div class="feed-modal__content feed-avatar-modal__content">
                <p class="feed-avatar-modal__name"><%= feed_user.name %></p>
              </div>

            </div>
          </div>
        </div>
      <% end %>
      <% end %>  <%# [HW] closes the if @feed_photos.none? / else block %>
    </div>

    <%# ============================================================ %>
    <%# TAB 2 — Gallery %>
    <%# ============================================================ %>
    <div class="tab-pane fade <%= 'show active' if params[:active_tab] == 'gallery' %>" id="tab-my-photos" role="tabpanel">
      <div class="photo-grid mt-3">

        <%# [HW] User's own photos %>
        <% @my_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div class="photo-card">
              <%# [HW] Icon bar — location label left, share + edit + delete right %>
              <div class="photo-card__actions">
                <%# [HW] Left side: location pin + truncated text (informational, not a button) %>
                <div class="photo-card__actions-left">
                  <% if photo.location.present? %>
                    <span class="photo-card__location-label">
                      <i class="fa-solid fa-location-dot"></i>
                      <span><%= photo.location %></span>
                    </span>
                  <% end %>
                </div>
                <%# [HW] Right side: share moved here from left, alongside edit and delete %>
                <div class="photo-card__actions-right">
                  <%= link_to toggle_share_photo_path(photo),
                      data: { turbo_method: :patch },
                      class: "photo-action-btn #{ photo.shared ? 'photo-action-btn--active' : '' }",
                      title: photo.shared ? "Unshare from feed" : "Share to community feed" do %>
                    <i class="fa-solid fa-share-nodes"></i>
                  <% end %>
                  <%= link_to edit_photo_path(photo), class: "photo-action-btn", title: "Edit caption" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%# [HW] Delete — dark navy default, red on hover %>
                  <%= button_to photo_path(photo), method: :delete,
                      class: "photo-action-btn photo-action-btn--danger",
                      title: "Delete photo",
                      data: { turbo_confirm: "Are you sure?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                </div>
              </div>

              <%# [HW] Wrapper makes the image a modal trigger — action buttons above are unaffected %>
              <div class="photo-card__img-wrap"
                   data-bs-toggle="modal"
                   data-bs-target="#gallery-modal-<%= photo.id %>">
                <%= image_tag photo.image, class: "photo-card__img" %>
              </div>

              <div class="photo-card__body">
                <p class="photo-card__desc"><%= photo.description %></p>
              </div>
            </div>
          <% end %>
        <% end %>

      </div>

      <%# [HW] Gallery focused-view modals — one per photo, reuses feed-modal styling %>
      <%# [HW] Shows location + caption only (no social features — private photos) %>
      <% @my_photos.each do |photo| %>
        <% if photo.image.attached? %>
          <div class="modal fade feed-modal" id="gallery-modal-<%= photo.id %>"
               tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content">
                <button class="feed-modal__close" data-bs-dismiss="modal" aria-label="Close">
                  <i class="fa-solid fa-xmark"></i>
                </button>
                <%# [HW] Location in the white frame above the image — right-aligned, top-right corner %>
                <% if photo.location.present? %>
                  <div class="feed-modal__above-img">
                    <i class="fa-solid fa-location-dot"></i>
                    <span><%= photo.location %></span>
                  </div>
                <% end %>
                <%= image_tag photo.image, class: "feed-modal__img", alt: photo.description %>
                <div class="feed-modal__content">
                  <p class="photo-card__desc">
                    <strong class="photo-card__author"><%= current_user.display_name %></strong>
                    <%= photo.description %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

    </div>

  </div>

  <%# ============================================================ %>
  <%# Add Photo Modal — triggered by the "+" next to the Gallery tab %>
  <%# ============================================================ %>
  <div class="modal fade add-photo-modal" id="add-photo-modal"
       tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="upload-tab">
          <%# [HW] data-controller wires up the Stimulus preview controller %>
          <div class="photo-card photo-card--upload photo-card--upload-lg"
               data-controller="photo-upload">
            <%= simple_form_for @photo, url: photos_path do |f| %>

              <%# [HW] Location field above the dropzone — mirrors its position on the posted photo card %>
              <%# [HW] data-controller wires up the Nominatim autocomplete Stimulus controller %>
              <div class="photo-card--upload__field-row" data-controller="location-autocomplete">
                <i class="fa-solid fa-location-dot photo-card--upload__field-icon"></i>
                <div class="location-autocomplete-wrap">
                  <%= f.input :location, label: false, placeholder: "Add a location...",
                      wrapper: false, input_html: {
                        class: "photo-card--upload__caption",
                        data: { "location-autocomplete-target": "input",
                                action: "input->location-autocomplete#search" }
                      } %>
                  <%# [HW] Dropdown is hidden by default; Stimulus populates and shows it on search %>
                  <div data-location-autocomplete-target="dropdown"
                       class="location-dropdown" hidden></div>
                </div>
              </div>

              <%# [HW] Grey square dropzone — placeholder shows until a file is chosen %>
              <label class="photo-card--upload__dropzone" for="photo_image">
                <span class="photo-card--upload__placeholder" data-photo-upload-target="placeholder">
                  <i class="fa-solid fa-camera photo-card--upload__camera"></i>
                  <span class="photo-card--upload__hint">Click to upload a photo</span>
                </span>
                <%# [HW] Preview image — hidden until a file is selected %>
                <img data-photo-upload-target="preview"
                     class="photo-card--upload__preview" alt="" />
              </label>

              <%# [HW] Hidden file input — triggers preview on change %>
              <%= f.input :image, as: :file, label: false,
                  input_html: {
                    id: "photo_image",
                    class: "photo-card--upload__input",
                    data: { action: "change->photo-upload#preview" }
                  } %>

              <div class="photo-card__body photo-card--upload__body">
                <%= f.input :description, label: false, placeholder: "Add a caption...",
                    wrapper: false, input_html: { class: "photo-card--upload__caption" } %>
                <%= f.submit "Upload", class: "photo-card--upload__submit" %>
              </div>

            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>


</div>
