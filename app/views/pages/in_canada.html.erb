<div class="container mt-4">
  <h1 class="mb-4">Canada Community</h1>

  <%# [HW] Community Feed shown first — the social content is the main draw of the page %>
  <%# [HW] Only photos explicitly marked shared:true appear here %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">Community Feed</h2>
    <% if @feed_photos.none? %>
      <p class="text-muted">No photos shared yet — be the first!</p>
    <% else %>
      <div class="photo-grid">
        <% @feed_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <%# [HW] photo-card--feed modifier switches body to left-aligned for IG style %>
            <div class="photo-card photo-card--feed">
              <%= image_tag photo.image, class: "photo-card__img" %>

              <div class="photo-card__body">
                <%# [HW] Reactions row: heart left, comment bubble right (pushed by margin-left: auto) %>
                <% already_liked = photo.likes.any? { |l| l.user_id == current_user.id } %>
                <%= render "likes/reactions", photo: photo %>

                <%# [HW] Instagram-style: bold author name followed by caption on the same line %>
                <p class="photo-card__desc">
                  <strong class="photo-card__author"><%= photo.user.name %></strong>
                  <%= photo.description %>
                </p>

                <%# [HW] Comments — bold author name + comment text, delete trash icon for own comments %>
                <div id="feed-comments-<%= photo.id %>" class="feed-comments">
                  <% photo.comments.each do |comment| %>
                    <%= render "comments/comment", comment: comment, photo: photo %>
                  <% end %>
                </div>

                <%# [HW] Comment form — posts to CommentsController#create via nested route %>
                <%= render "comments/form", photo: photo %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# [HW] My Photos moved to the bottom — personal gallery is secondary to the community feed %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">My Photos</h2>
    <%# [HW] Grid is always rendered — it always contains at least the upload card %>
    <div class="photo-grid">

      <%# [HW] Upload card is permanently the first slot in the grid %>
      <%# [HW] simple_form_for @photo with url: photos_path posts to PhotosController#create %>
      <div class="photo-card photo-card--upload">
        <%= simple_form_for @photo, url: photos_path do |f| %>
          <div class="photo-card--upload__icon">
            <i class="fa-solid fa-camera"></i>
          </div>
          <%= f.input :image, as: :file, label: false %>
          <%= f.input :description, placeholder: "Add a caption..." %>
          <%= f.submit "Upload", class: "btn btn-primary btn-sm w-100 mt-2" %>
        <% end %>
      </div>

      <%# [HW] User's own photos follow the upload card %>
      <% @my_photos.each do |photo| %>
        <% if photo.image.attached? %>
          <div class="photo-card">
            <%# [HW] Icon bar sits on the white card background above the photo %>
            <%# [HW] Left side: share. Right side: edit + delete %>
            <div class="photo-card__actions">
              <div class="photo-card__actions-left">
                <%= link_to toggle_share_photo_path(photo),
                    data: { turbo_method: :patch },
                    class: "photo-action-btn #{ photo.shared ? 'photo-action-btn--active' : '' }",
                    title: photo.shared ? "Unshare from feed" : "Share to community feed" do %>
                  <i class="fa-solid fa-share-nodes"></i>
                <% end %>
              </div>
              <div class="photo-card__actions-right">
                <%= link_to edit_photo_path(photo), class: "photo-action-btn", title: "Edit caption" do %>
                  <i class="fa-solid fa-pen"></i>
                <% end %>
                <%# [HW] Delete — dark navy default, red on hover (unified with comment delete) %>
                <%= button_to photo_path(photo), method: :delete,
                    class: "photo-action-btn photo-action-btn--danger",
                    title: "Delete photo",
                    data: { turbo_confirm: "Are you sure?" } do %>
                  <i class="fa-solid fa-trash"></i>
                <% end %>
              </div>
            </div>

            <%= image_tag photo.image, class: "photo-card__img" %>

            <%# [HW] Caption only below the photo %>
            <div class="photo-card__body">
              <p class="photo-card__desc"><%= photo.description %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
