<div class="post-canada">

  <%# ── Hero heading ── %>
  <div class="post-canada__hero">
    <h1 class="post-canada__hero-title">
      Welcome back,<br>
      <span class="post-canada__hero-accent"><%= current_user.display_name %>!</span>
    </h1>
  </div>

  <p class="post-canada__intro">You did something incredible. We hope you enjoyed your adventure in Canada, made friends and grew as a person. We want to help you to get the best out of it. The best way is to reflect on it. We are happy to also help you on this last final steps with some helpful questions. After you answered them you get your personal summary with helpful advice from your AI coach.</p>

  <%# ── AI Summary — dark navy card ── %>
  <div class="ai-summary-panel" id="ai-summary"
       data-controller="ai-summary"
       data-ai-summary-url-value="<%= status_questionnaire_path(@questionnaire, format: :json) %>">

    <div class="ai-summary__icon">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
    </div>
    <div class="ai-summary__title">Your Personal Growth Summary</div>

    <% if @questionnaire.submitted? %>
      <p class="ai-summary__body">
        Your answers are in. Your AI life coach is ready to reflect your journey back to you — growth, challenges, and all.
      </p>

      <% if @questionnaire.ai_summary.present? %>
        <div class="ai-summary__response" data-ai-summary-target="content">
          <%= simple_format(@questionnaire.ai_summary) %>
        </div>
      <% else %>
        <div class="ai-summary__spinner" data-ai-summary-target="spinner" data-pending="true">
          <i class="fa-solid fa-circle-notch fa-spin"></i>
          <p class="ai-summary__spinner-label">Generating your personal story… this takes about 20 seconds.</p>
        </div>
        <div class="ai-summary__response d-none" data-ai-summary-target="content"></div>
      <% end %>

    <% else %>
      <p class="ai-summary__body">
        Save your answers below and unlock a personalised summary of your exchange year — written just for you.
      </p>

      <%= button_to questionnaire_path(@questionnaire), method: :patch,
            params: { submitted: true },
            class: "ai-summary__unlock-btn",
            form: { data: { turbo_confirm: "Ready? Make sure you've saved all your answers first!" } } do %>
        <i class="fa-solid fa-lock-open"></i> Unlock My Personal Growth Summary
      <% end %>
    <% end %>
  </div>

  <%# ── Reflection Questionnaire — navy collapsible card ── %>
  <% answered_count = @questions.count { |q| q.answers.first&.text.present? } %>
  <% question_icons = [
    "fa-solid fa-dumbbell",
    "fa-solid fa-globe",
    "fa-solid fa-rocket",
    "fa-solid fa-comments",
    "fa-solid fa-feather",
    "fa-solid fa-house",
    "fa-solid fa-bullseye",
    "fa-solid fa-envelope"
  ] %>

  <div class="reflect-checklist" data-controller="collapsible"
       data-collapsible-show-label-value="Show questions"
       data-collapsible-hide-label-value="Hide questions">
    <div class="reflect-checklist__header" data-action="click->collapsible#toggle">
      <p class="reflect-checklist__header-status"><%= answered_count %>/<%= @questions.count %> ANSWERED</p>
      <div class="reflect-checklist__header-body">
        <div class="reflect-checklist__header-icon">
          <i class="fa-solid fa-clipboard-question"></i>
        </div>
        <h3 class="reflect-checklist__header-title">Reflection Questionnaire</h3>
      </div>
      <button class="reflect-checklist__header-btn" data-collapsible-target="chevron">Show questions</button>
    </div>

    <div class="reflect-checklist__list collapsible--hidden" data-collapsible-target="content">
      <p class="reflect-checklist__hint">Answer at your own pace — save each answer individually, then unlock your summary.</p>

      <% @questions.each_with_index do |question, index| %>
        <div class="reflect-item reflect-item--expandable"
             data-controller="task-expand question-card"
             data-question-card-questionnaire-id-value="<%= @questionnaire.id %>"
             data-question-card-question-id-value="<%= question.id %>"
             data-question-card-submitted-value="<%= @questionnaire.submitted? %>">

          <div class="reflect-item__row" data-action="click->task-expand#toggle">
            <i class="<%= question_icons[index % question_icons.length] %> reflect-item__icon"></i>
            <span class="reflect-item__question"><%= question.text %></span>
            <i class="fa-solid fa-chevron-down prep-checklist__chevron" data-task-expand-target="chevron"></i>
          </div>

          <div class="prep-checklist__item-desc reflect-item__body" data-task-expand-target="desc">
            <p class="question-card__answer-text" data-question-card-target="display"></p>
            <div data-question-card-target="editor">
              <%= text_area_tag "answers[#{question.id}]",
                                question.answers.first&.text,
                                class: "form-control reflect-item__textarea",
                                rows: 3,
                                placeholder: "Share your thoughts...",
                                data: { "question-card-target": "textarea" } %>
            </div>
            <div class="reflect-item__actions">
              <button type="button"
                      class="reflect-item__edit-btn"
                      data-question-card-target="editBtn"
                      data-action="click->question-card#edit">
                <i class="fa-solid fa-pen"></i> Edit
              </button>
              <button type="button"
                      class="reflect-item__save-btn"
                      data-question-card-target="saveBtn"
                      data-action="click->question-card#save">
                <i class="fa-solid fa-floppy-disk"></i> Save
              </button>
            </div>
          </div>
        </div>
      <% end %>

      <% if @questionnaire.submitted? %>
        <div class="reflect-checklist__footer">
          <span class="badge bg-success">
            <i class="fa-solid fa-wand-magic-sparkles"></i> Summary created
          </span>
          <%= button_to questionnaire_path(@questionnaire), method: :patch,
                params: { submitted: false },
                class: "btn-revert-draft",
                form: { class: "d-inline" },
                title: "Go back to edit mode" do %>
            <i class="fa-solid fa-rotate-left"></i>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

</div>
